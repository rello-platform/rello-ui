# Configurator server environment (configurator/server)
#
# This dev/operator tool commits directly to the rello-ui repo via GITHUB_TOKEN
# and is therefore a supply-chain write primitive. The write endpoints are
# auth-gated (SECURITY AUDIT PKG-H1) — CONFIGURATOR_SECRET is REQUIRED for any
# commit/upload/delete to succeed. With it unset the server fails CLOSED (503).

# --- GitHub write target (existing) ---
# Personal access / fine-grained token scoped to contents:write on the single
# rello-ui repo only (least privilege).
GITHUB_TOKEN=
GITHUB_OWNER=rello-platform
GITHUB_REPO=rello-ui
GITHUB_BRANCH=main

# --- Write auth (PKG-H1) — REQUIRED ---
# Shared operator secret. Every write request must send it as
#   x-configurator-secret: <CONFIGURATOR_SECRET>
# (or Authorization: Bearer <CONFIGURATOR_SECRET>). The Configurator UI prompts
# the operator for it ("Unlock writes" in the header) and stores it in
# sessionStorage. Generate a long random value, e.g.: openssl rand -hex 32
CONFIGURATOR_SECRET=

# --- CORS allowlist (PKG-H1) ---
# Comma-separated list of origins allowed to call the API cross-origin. In
# production set this to the deployed Configurator UI origin (the UI is served
# same-origin, so this is only needed if a separate front-end origin exists).
# Localhost dev origins are auto-allowed when NODE_ENV != production.
CONFIGURATOR_ALLOWED_ORIGINS=

# --- Runtime ---
# PORT defaults to 3001. NODE_ENV=production serves the built UI + locks CORS to
# the explicit allowlist above.
# PORT=3001
# NODE_ENV=production
