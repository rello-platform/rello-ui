{
  "name": "@rello-platform/ui",
  "version": "1.0.1",
  "description": "Shared UI component library for Rello applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles": "./src/styles/index.css",
    "./tokens": "./src/styles/design-tokens.css",
    "./app-overrides": "./tokens/app-overrides.json"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist",
    "src",
    "tokens"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "tailwindcss": "^4.0.0"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.3.0",
    "@radix-ui/react-dialog": "^1.1.0",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.2.0",
    "@radix-ui/react-slot": "^1.2.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "iconoir-react": "^7.11.0",
    "tailwind-merge": "^3.0.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.17",
    "@storybook/addon-essentials": "^8.6.17",
    "@storybook/addon-interactions": "^8.6.17",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react-vite": "^8.6.17",
    "@storybook/test": "^8.6.17",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^26.1.0",
    "storybook": "^8.6.17",
    "tsup": "^8.0.0",
    "typescript": "^5",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rello-platform/rello-ui.git"
  },
  "keywords": [
    "react",
    "ui",
    "components",
    "design-system",
    "rello"
  ],
  "author": "Kelly Sansom",
  "license": "MIT"
}
